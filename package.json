{
  "name": "evolution-pebble",
  "version": "0.1.0",
  "description": "Эволюция Гальки — кликер/idle игра для Яндекс.Игр",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx",
    "test": "jest --config jest.config.ts",
    "test:e2e": "playwright test",
    "analyze": "vite build --mode analyze"
  },
  "keywords": [
    "clicker",
    "idle",
    "yandex-games",
    "phaser"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "@vitejs/plugin-legacy": "^5.3.0",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "@types/jest": "^29.5.11",
    "@playwright/test": "^1.41.0"
  },
  "dependencies": {
    "phaser": "^3.70.0"
  }
}
